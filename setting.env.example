# Z-Pulse 설정 파일 예시
# 이 파일을 'setting.env'로 복사하고 실제 값으로 수정하세요.
# 토큰, 채팅 ID, 로컬 경로, 비밀값은 예시값을 그대로 사용하지 않습니다.

# ========================================
# [BOOT] 메인 부트/인증/기능 토글
# ========================================
# 모니터링할 프로그램들이 있는 기본 디렉토리
# Z-Flow 슬롯 런타임 디렉토리 상위 경로로도 사용됩니다.
TARGET_DIR="/Users/user/Documents/toolkit"
# 감시할 프로세스 이름
PROCESS_NAME="2oolkit-bot-macos-arm64"
# 텔레그램 봇 토큰 (@BotFather에서 생성)
TELEGRAM_BOT_TOKEN="your_bot_token_here"
TELEGRAM_CHAT_ID="your_bot_chat_id_here"
# 경제지표 캘린더 활성화
ECONOMIC_CALENDAR_ENABLED=true
# 경제지표 일일 업데이트 시간 (0-23)
ECONOMIC_UPDATE_HOUR=06
# ========================================
# [RUNTIME] 운영 파라미터
# ========================================
# 메모리 사용량 임계치 초과 시 텔레그램 알림 발송 여부
MEMORY_ALERT_ENABLED=true

# Rapid Entry Guard 강제 문구 목록
RAPID_ENTRY_GUARD_FORCE_PHRASES="최초 진입,추가 진입"

# pair_trading 전략 전용 키 (화이트리스트, 공적분 필터, 리스크 파라미터 등)는
# z_flow/strategy/pair_trading/setting.env.example 참고.

# ========================================
# [Z-FLOW] 독립 프로세스 Z-Flow 설정
# ========================================
# z_pulse/ 와 z_flow/ 를 같은 상위 디렉토리에 둡니다.
# Z-Flow 활성화 여부 (false = 외부 봇(GRVT-P-*) 방식 유지)
Z_FLOW_ENABLED=false
# Z_FLOW_PATH는 setup_bot이 sibling z_flow를 감지해 자동 기록합니다.
# 일반 운영에서는 직접 경로를 입력하거나 임의 경로로 수정하지 않습니다.
Z_FLOW_PATH=""
